generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Language {
  ja
  zh
  en
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  banned
}

enum OrderStatus {
  pending
  paid
  fulfilled
  cancelled
  refunded
}

enum PhoneStatus {
  available
  assigned
  disabled
  expired
}

enum AssignmentStatus {
  active
  expired
  suspended
}

enum SupportTicketStatus {
  open
  replied
  closed
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  passwordHash      String          @map("password_hash")
  name              String?
  preferredLanguage Language        @default(ja) @map("preferred_language")
  role              UserRole        @default(user)
  status            UserStatus      @default(active)
  lastLoginAt       DateTime?       @map("last_login_at")
  lastLoginIp       String?         @map("last_login_ip")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  orders            Order[]
  assignments       Assignment[]
  supportTickets    SupportTicket[]
  adminLogs         AdminLog[]      @relation("AdminActor")
  passwordResetTokens PasswordResetToken[]
  vmosApiLogs       VmosApiLog[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Plan {
  id               String   @id @default(cuid())
  code             String   @unique
  nameZh           String   @map("name_zh")
  nameJa           String   @map("name_ja")
  nameEn           String   @map("name_en")
  descriptionZh    String   @map("description_zh")
  descriptionJa    String   @map("description_ja")
  descriptionEn    String   @map("description_en")
  price            Decimal  @db.Decimal(12, 2)
  currency         String   @default("JPY")
  durationDays     Int?     @map("duration_days")
  availableRegions String[] @default([]) @map("available_regions")
  stockQuantity    Int?     @map("stock_quantity")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  orders           Order[]

  @@map("plans")
}

model Order {
  id              String      @id @default(cuid())
  userId          String      @map("user_id")
  planId          String      @map("plan_id")
  planName        String?     @map("plan_name")
  amount          Decimal     @db.Decimal(12, 2)
  currency        String      @default("JPY")
  status          OrderStatus @default(pending)
  paymentProvider String?     @map("payment_provider")
  paymentId       String?     @map("payment_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  paidAt          DateTime?   @map("paid_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  user            User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  plan            Plan        @relation(fields: [planId], references: [id], onDelete: Restrict)
  assignment      Assignment?

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@map("orders")
}

model Phone {
  id           String       @id @default(cuid())
  internalName String       @unique @map("internal_name")
  vmosPadCode  String       @unique @map("vmos_pad_code")
  region       String?
  status       PhoneStatus  @default(available)
  vmosExpireAt DateTime?    @map("vmos_expire_at")
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  assignments  Assignment[]
  apiLogs      VmosApiLog[]

  @@index([status])
  @@index([region])
  @@map("phones")
}

model Assignment {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  phoneId      String           @map("phone_id")
  orderId      String           @unique @map("order_id")
  startedAt    DateTime         @map("started_at")
  expiresAt    DateTime         @map("expires_at")
  status       AssignmentStatus @default(active)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  user         User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  phone        Phone            @relation(fields: [phoneId], references: [id], onDelete: Restrict)
  order        Order            @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([phoneId])
  @@index([status])
  @@map("assignments")
}

model VmosApiLog {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  phoneId       String?  @map("phone_id")
  action        String
  requestStatus String   @map("request_status")
  errorMessage  String?  @map("error_message")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  phone         Phone?   @relation(fields: [phoneId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([phoneId])
  @@index([action])
  @@map("vmos_api_logs")
}

model Setting {
  id             String   @id @default(cuid())
  key            String   @unique
  encryptedValue String   @map("encrypted_value")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model SupportTicket {
  id         String              @id @default(cuid())
  userId     String              @map("user_id")
  title      String
  message    String
  status     SupportTicketStatus @default(open)
  adminReply String?             @map("admin_reply")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  user       User                @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String?  @map("admin_id")
  action     String
  targetType String   @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  admin      User?    @relation("AdminActor", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([targetType, targetId])
  @@map("admin_logs")
}
